  @Label("Name")
  String name;

  @Label("Success")
  @Description("Success or failure of the unload operation")
  boolean success;

  @Label("Error Message")
  @Description("In case of an unload error, error description")
  String errorMessage;
}

@Name("jdk.NativeMemoryUsage")
@Category({"Java Virtual Machine", "Memory"})
@Label("Native Memory Usage Per Type")
@Description("Native memory usage for a given memory tag in the JVM")
class NativeMemoryUsage extends jdk.jfr.Event {
  @Label("Start Time")
  @Timestamp("TICKS")
  long startTime;

  @Label("Memory Type")
  @Description("Type used for the native memory allocation")
  String type;

  @Unsigned
  @DataAmount("BYTES")
  @Label("Reserved Memory")
  @Description("Reserved bytes for this type")
  long reserved;

  @Unsigned
  @DataAmount("BYTES")
  @Label("Committed Memory")
  @Description("Committed bytes for this type")
  long committed;
}

@Name("jdk.NativeMemoryUsageTotal")
@Category({"Java Virtual Machine", "Memory"})
@Label("Total Native Memory Usage")
@Description("Total native memory usage for the JVM. Might not be the exact sum of the NativeMemoryUsage events due to timeing.")
class NativeMemoryUsageTotal extends jdk.jfr.Event {
  @Label("Start Time")
  @Timestamp("TICKS")
  long startTime;

  @Unsigned
  @DataAmount("BYTES")
  @Label("Reserved Memory")
  @Description("Total amount of reserved bytes for the JVM")
  long reserved;

  @Unsigned
  @DataAmount("BYTES")
  @Label("Committed Memory")
  @Description("Total amount of committed bytes for the JVM")
  long committed;
}

