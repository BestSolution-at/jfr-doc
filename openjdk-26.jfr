@Name("jdk.CPUTimeSample")
@Category({"Java Virtual Machine", "Profiling"})
@Label("CPU Time Sample")
@Description("Snapshot of a threads state from the CPU time sampler, both threads executing native and Java code are included. The throttle setting can be either an upper bound for the event emission rate, e.g. 100/s, or the cpu-time period, e.g. 10ms, with s, ms, us and ns supported as time units.")
@Experimental
class CPUTimeSample extends jdk.jfr.Event {
  @Label("Start Time")
  @Timestamp("TICKS")
  long startTime;

  @Label("Stack Trace")
  StackTrace stackTrace;

  @Label("Thread")
  Thread eventThread;

  @Label("Failed")
  @Description("Failed to obtain the stack trace")
  boolean failed;

  @Unsigned
  @Timespan("TICKS")
  @Label("CPU Time Sampling Period")
  long samplingPeriod;

  @Label("Biased")
  @Description("The sample is safepoint-biased")
  boolean biased;
}

